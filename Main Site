<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <title>Accurio - The fact-checked search engine</title>
    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            background-color: floralwhite;
        }
        .bottom {
            background-color: dodgerblue;
            width: 100%;
            height: 120px;
            position: fixed;
            bottom: 0;
        }
        .image-logo {
            display: flex;
            height: 30%;
            position: absolute;
            top: 35%;
            left: 49%;
            transform: translate(-50%, -50%);
        }
        .About-page {
            font-size: 170%;
            position: fixed;
            left: 12.5%;
            top: 92.5%;
            font-family: 'Berlin Sans FB';
            z-index: 1;
        }        
        .Contact-page {
            font-size: 170%;
            position: fixed;
            left: 20%;
            top: 92.5%;
            font-family: 'Berlin Sans FB';
            z-index: 1;
        }       
        .Home-page {
            font-size: 170%;
            position: fixed;
            left: 5%;
            top: 92.5%;
            font-family: 'Berlin Sans FB';
            z-index: 1;
        }
        .Contact.page, .About-page, a.active {
            color: ghostwhite;
        }
    </style>
</head>

<body>
    <div class="image-logo">
        <img src="https://i.ibb.co/dM7ctKn/small-update.png" alt="Accurio">
    </div>

    <div class="search-bar" style="position: fixed; top: 50%; left: 32.5%; width: 35%;">
        <script async src="https://cse.google.com/cse.js?cx=6e2ab4daa6c61d3ca"></script>
        <div class="gcse-searchbox"></div>
    </div>

    <div class="About-page">
        <a class="active" href="">About</a>
    </div>

    <div class="Contact-page">
        <a class="active" href="">Contact</a>
    </div>

    <div class="Home-page">
        <a class="active" href="">Home</a>
    </div>

    <div class="bottom"></div>

    <div class="gcse-searchresults"></div>

</body>
</html>
